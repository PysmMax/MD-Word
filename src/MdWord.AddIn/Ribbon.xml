<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon><tabs>
    <tab idMso="TabHome">
      <group id="grpMdWord" label="Markdown" insertAfterMso="GroupClipboard">
        <button id="btnPasteMd" label="Insert Markdown" size="large" imageMso="Paste"
                onAction="OnPasteMarkdown" screentip="Insert Markdown from the clipboard as formatted text"/>
        <button id="btnCopyMd" label="Copy as Markdown" size="large" imageMso="Copy"
                onAction="OnCopyMarkdown" screentip="Copy the selection as Markdown"/>
      </group>
    </tab>
  </tabs></ribbon>
</customUI>
